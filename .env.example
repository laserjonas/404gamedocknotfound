# GameDock Manager configuration
# Copy this file to .env and adjust values. Never commit .env.

# Interface the API binds to. Keep 127.0.0.1 when running behind a reverse proxy.
GAMEDOCK_HOST=127.0.0.1

# Port for the API / web UI.
GAMEDOCK_PORT=8340

# Base directory for application data (SQLite database, job logs).
# Production recommendation: /var/lib/gamedock
GAMEDOCK_DATA_DIR=./data

# Directory that contains one sub-directory per game server instance.
# Production recommendation: /var/lib/gamedock/instances
GAMEDOCK_INSTANCE_DIR=./data/instances

# Directory where backup archives are stored.
# Production recommendation: /var/lib/gamedock/backups
GAMEDOCK_BACKUP_DIR=./data/backups

# Database connection. Only sqlite is supported right now.
# Format: sqlite:<path-to-file>  (relative paths resolve against GAMEDOCK_DATA_DIR)
GAMEDOCK_DATABASE_URL=sqlite:gamedock.sqlite

# Secret used to sign session cookies. MUST be a long random string in production.
# Generate one with: openssl rand -hex 32
GAMEDOCK_SESSION_SECRET=change-me-to-a-long-random-string

# Absolute path to the steamcmd executable. Leave as "steamcmd" if it is on PATH.
GAMEDOCK_STEAMCMD_PATH=steamcmd

# "production" or "development"
GAMEDOCK_NODE_ENV=development

# Maximum upload size for the file manager, in megabytes.
GAMEDOCK_MAX_UPLOAD_MB=512

# Set to "true" to mark session cookies Secure (requires HTTPS / reverse proxy TLS).
GAMEDOCK_SECURE_COOKIES=false
