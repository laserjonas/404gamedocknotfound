# GameDock Discord bot configuration
# Copy this file to .env and fill in the values below. Never commit .env.
# Full setup walkthrough: docs/DISCORD_BOT.md

# From the Discord Developer Portal (https://discord.com/developers/applications)
# -> your application -> Bot -> Token.
DISCORD_BOT_TOKEN=

# The Discord server (guild) this bot operates in. Right-click the server
# icon in Discord with Developer Mode enabled -> Copy Server ID.
DISCORD_GUILD_ID=

# The URL your GameDock panel is reachable at, e.g. https://gamedock.example.com
GAMEDOCK_API_URL=

# An API token for an ADMIN GameDock account (Settings -> API tokens ->
# Create a token). Treat this like a root credential: it can create, install
# and manage any instance on the panel.
GAMEDOCK_API_TOKEN=

# Where this bot keeps its own small SQLite database (role quotas + which
# Discord user requested which instance). Production recommendation:
# /var/lib/gamedock-discord-bot
GAMEDOCK_BOT_DATA_DIR=./data

# How often (in minutes) to check GameDock for instances that were deleted
# outside the bot (e.g. by an admin in the web UI), so quota counts don't
# get stuck.
RECONCILE_INTERVAL_MINUTES=15

# How often (in minutes) to check whether GameDock was redeployed via
# self-update (Settings -> Application updates). GameDock's self-update
# only restarts the main API process - it doesn't know this bot exists as
# a separate systemd unit - so this bot restarts itself when it notices,
# picking up its own freshly-rsynced code (its own systemd unit's
# Restart=always brings it back up).
UPDATE_CHECK_INTERVAL_MINUTES=5
