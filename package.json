{
  "name": "gamedock-manager",
  "version": "0.4.0",
  "private": true,
  "description": "GameDock Manager - self-hosted game server management panel for Debian",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel --filter @gamedock/api --filter @gamedock/web dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "gamedock": "pnpm --filter @gamedock/api cli"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0"
  }
}
