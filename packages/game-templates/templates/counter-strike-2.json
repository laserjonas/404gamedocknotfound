{
  "id": "counter-strike-2",
  "name": "Counter-Strike 2 Dedicated Server",
  "description": "CS2 dedicated server, installed via SteamCMD (anonymous). ~35 GB download.",
  "installMethod": "steamcmd",
  "steam": {
    "appId": 730,
    "anonymous": true
  },
  "os": ["linux"],
  "ports": [{ "name": "Game/Query", "port": 27015, "protocol": "both" }],
  "start": {
    "executable": "./game/bin/linuxsteamrt64/cs2",
    "args": [
      "-dedicated",
      "-port",
      "{{GAME_PORT}}",
      "+map",
      "{{MAP}}",
      "+game_type",
      "{{GAME_TYPE}}",
      "+game_mode",
      "{{GAME_MODE}}",
      "+hostname",
      "{{SERVER_NAME}}"
    ],
    "workingDir": "."
  },
  "env": {
    "LD_LIBRARY_PATH": "./game/bin/linuxsteamrt64"
  },
  "stop": {
    "method": "command",
    "command": "quit",
    "timeoutSeconds": 60
  },
  "console": {
    "supportsInput": true
  },
  "configFiles": [
    {
      "path": "game/csgo/cfg/server.cfg",
      "description": "Server configuration executed on map load",
      "createdByServer": true
    }
  ],
  "variables": [
    {
      "key": "SERVER_NAME",
      "label": "Server name",
      "default": "GameDock CS2",
      "required": true
    },
    {
      "key": "GAME_PORT",
      "label": "Game port",
      "default": "27015",
      "required": true,
      "pattern": "[0-9]{2,5}"
    },
    {
      "key": "MAP",
      "label": "Start map",
      "default": "de_dust2",
      "required": true,
      "pattern": "[A-Za-z0-9_]{1,64}"
    },
    {
      "key": "GAME_TYPE",
      "label": "Game type (0 = competitive/casual)",
      "default": "0",
      "required": true,
      "pattern": "[0-9]"
    },
    {
      "key": "GAME_MODE",
      "label": "Game mode (0 = casual, 1 = competitive)",
      "default": "0",
      "required": true,
      "pattern": "[0-9]"
    }
  ],
  "notes": "Public (internet-visible) servers need a Steam Game Server Login Token (GSLT) from https://steamcommunity.com/dev/managegameservers - add \"+sv_setsteamaccount\" and your token as extra startup arguments in the startup editor."
}
