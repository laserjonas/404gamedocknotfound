{
  "id": "factorio",
  "name": "Factorio Headless Server",
  "description": "Factorio headless dedicated server downloaded from factorio.com (no Steam required).",
  "installMethod": "url",
  "urlInstall": {
    "url": "https://factorio.com/get-download/{{FACTORIO_VERSION}}/headless/linux64",
    "archive": "tar"
  },
  "os": ["linux"],
  "ports": [
    { "name": "Game", "port": 34197, "protocol": "udp" },
    { "name": "RCON", "port": 27015, "protocol": "tcp" }
  ],
  "start": {
    "executable": "./factorio/bin/x64/factorio",
    "args": [
      "--start-server-load-latest",
      "--port",
      "{{GAME_PORT}}",
      "--server-settings",
      "{{GAMEDOCK_INSTANCE_DIR}}/server-settings.json"
    ],
    "workingDir": "."
  },
  "env": {},
  "stop": {
    "method": "command",
    "command": "/quit",
    "timeoutSeconds": 60
  },
  "console": {
    "supportsInput": true
  },
  "configFiles": [
    {
      "path": "server-settings.json",
      "description": "Server settings (name, visibility, credentials)"
    },
    { "path": "factorio/saves", "description": "Save files", "createdByServer": true }
  ],
  "setupFiles": [
    {
      "path": "server-settings.json",
      "content": "{\n  \"name\": \"{{SERVER_NAME}}\",\n  \"description\": \"Factorio server managed by GameDock\",\n  \"tags\": [],\n  \"max_players\": {{MAX_PLAYERS}},\n  \"visibility\": { \"public\": false, \"lan\": true },\n  \"username\": \"\",\n  \"token\": \"\",\n  \"game_password\": \"{{SERVER_PASSWORD}}\",\n  \"require_user_verification\": false,\n  \"autosave_interval\": 10,\n  \"autosave_slots\": 5,\n  \"auto_pause\": true\n}\n"
    }
  ],
  "variables": [
    {
      "key": "FACTORIO_VERSION",
      "label": "Factorio version (or \"stable\" / \"latest\")",
      "default": "stable",
      "required": true,
      "pattern": "[A-Za-z0-9.]{1,20}"
    },
    {
      "key": "GAME_PORT",
      "label": "Game port (UDP)",
      "default": "34197",
      "required": true,
      "pattern": "[0-9]{2,5}"
    },
    {
      "key": "SERVER_NAME",
      "label": "Server name",
      "default": "GameDock Factorio",
      "required": true
    },
    {
      "key": "MAX_PLAYERS",
      "label": "Max players (0 = unlimited)",
      "default": "0",
      "required": true,
      "pattern": "[0-9]{1,3}"
    },
    {
      "key": "SERVER_PASSWORD",
      "label": "Game password (empty = none)",
      "default": "",
      "required": false,
      "secret": true
    }
  ],
  "notes": "Before the first start, create a save once: open the startup editor and temporarily set the arguments to --create ./factorio/saves/world.zip, start the server once, then restore the default arguments. Public visibility requires a factorio.com account in server-settings.json."
}
