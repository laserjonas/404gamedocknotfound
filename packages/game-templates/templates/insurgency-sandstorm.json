{
  "id": "insurgency-sandstorm",
  "name": "Insurgency: Sandstorm Dedicated Server",
  "description": "Insurgency: Sandstorm dedicated server, installed via SteamCMD (anonymous).",
  "installMethod": "steamcmd",
  "steam": {
    "appId": 581330,
    "anonymous": true
  },
  "os": ["linux"],
  "ports": [
    { "name": "Game", "port": 27102, "protocol": "udp" },
    { "name": "Query", "port": 27131, "protocol": "udp" }
  ],
  "start": {
    "executable": "./Insurgency/Binaries/Linux/InsurgencyServer-Linux-Shipping",
    "args": [
      "{{MAP}}?Scenario={{SCENARIO}}?MaxPlayers={{MAX_PLAYERS}}",
      "-Port={{GAME_PORT}}",
      "-QueryPort={{QUERY_PORT}}",
      "-hostname={{SERVER_NAME}}",
      "-log"
    ],
    "workingDir": "."
  },
  "env": {},
  "stop": {
    "method": "sigterm",
    "timeoutSeconds": 60
  },
  "console": {
    "supportsInput": false
  },
  "configFiles": [
    {
      "path": "Insurgency/Saved/Config/LinuxServer",
      "description": "Game.ini (admins, bans, MOTD), created after first run",
      "createdByServer": true
    }
  ],
  "variables": [
    {
      "key": "SERVER_NAME",
      "label": "Server name",
      "default": "GameDock Sandstorm",
      "required": true
    },
    {
      "key": "MAP",
      "label": "Map",
      "default": "Oilfield",
      "required": true,
      "pattern": "[A-Za-z0-9_]{1,64}"
    },
    {
      "key": "SCENARIO",
      "label": "Scenario",
      "default": "Scenario_Oilfield_Push_Security",
      "required": true,
      "pattern": "[A-Za-z0-9_]{1,128}"
    },
    {
      "key": "GAME_PORT",
      "label": "Game port (UDP)",
      "default": "27102",
      "required": true,
      "pattern": "[0-9]{2,5}"
    },
    {
      "key": "QUERY_PORT",
      "label": "Query port (UDP)",
      "default": "27131",
      "required": true,
      "pattern": "[0-9]{2,5}"
    },
    {
      "key": "MAX_PLAYERS",
      "label": "Max players",
      "default": "28",
      "required": true,
      "pattern": "[0-9]{1,3}"
    }
  ],
  "notes": "A Steam Game Server Login Token (GSLT), generated against the base game's appid 581320 at https://steamcommunity.com/dev/managegameservers, is recommended for public visibility - add it via Game.ini or an extra -GSLTToken= startup argument. Older server builds are 32-bit only; if the server fails to start, install lib32gcc-s1/lib32stdc++6 (already covered by scripts/install.sh for SteamCMD)."
}
