{
  "id": "palworld",
  "name": "Palworld Dedicated Server",
  "description": "Palworld dedicated server, installed via SteamCMD (anonymous).",
  "installMethod": "steamcmd",
  "steam": {
    "appId": 2394010,
    "anonymous": true
  },
  "os": ["linux"],
  "ports": [
    { "name": "Game", "port": 8211, "protocol": "udp" },
    { "name": "Query", "port": 27015, "protocol": "udp" }
  ],
  "start": {
    "executable": "./PalServer.sh",
    "args": [
      "-port={{GAME_PORT}}",
      "-players={{MAX_PLAYERS}}",
      "-useperfthreads",
      "-NoAsyncLoadingThread",
      "-UseMultithreadForDS"
    ],
    "workingDir": "."
  },
  "env": {},
  "stop": {
    "method": "sigterm",
    "timeoutSeconds": 60
  },
  "console": {
    "supportsInput": false
  },
  "configFiles": [
    {
      "path": "Pal/Saved/Config/LinuxServer/PalWorldSettings.ini",
      "description": "Main server settings (created after first run)",
      "createdByServer": true
    }
  ],
  "variables": [
    {
      "key": "GAME_PORT",
      "label": "Game port (UDP)",
      "default": "8211",
      "required": true,
      "pattern": "[0-9]{2,5}"
    },
    {
      "key": "MAX_PLAYERS",
      "label": "Max players",
      "default": "32",
      "required": true,
      "pattern": "[0-9]{1,3}"
    }
  ],
  "notes": "Server name, password and most gameplay settings live in PalWorldSettings.ini, created after the first start. Copy defaults from DefaultPalWorldSettings.ini in the install directory. Enable RCON in the INI for graceful remote shutdowns."
}
