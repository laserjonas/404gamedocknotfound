{
  "id": "squad",
  "name": "Squad Dedicated Server",
  "description": "Squad dedicated server, installed via SteamCMD (anonymous). Large download (~15 GB).",
  "installMethod": "steamcmd",
  "steam": {
    "appId": 403240,
    "anonymous": true
  },
  "os": ["linux"],
  "ports": [
    { "name": "Game", "port": 7787, "protocol": "udp" },
    { "name": "Game+1", "port": 7788, "protocol": "udp" },
    { "name": "Beacon", "port": 15000, "protocol": "both" },
    { "name": "Query", "port": 27165, "protocol": "both" },
    { "name": "RCON", "port": 21114, "protocol": "tcp" }
  ],
  "start": {
    "executable": "./SquadGameServer.sh",
    "args": [
      "Port={{GAME_PORT}}",
      "QueryPort={{QUERY_PORT}}",
      "FIXEDMAXPLAYERS={{MAX_PLAYERS}}",
      "-log"
    ],
    "workingDir": "."
  },
  "env": {},
  "stop": {
    "method": "sigterm",
    "timeoutSeconds": 60
  },
  "console": {
    "supportsInput": false
  },
  "configFiles": [
    {
      "path": "SquadGame/ServerConfig",
      "description": "Rcon.cfg, Admins.cfg and other server config, created after first run",
      "createdByServer": true
    }
  ],
  "variables": [
    {
      "key": "GAME_PORT",
      "label": "Game port (UDP)",
      "default": "7787",
      "required": true,
      "pattern": "[0-9]{2,5}"
    },
    {
      "key": "QUERY_PORT",
      "label": "Query port",
      "default": "27165",
      "required": true,
      "pattern": "[0-9]{2,5}"
    },
    {
      "key": "MAX_PLAYERS",
      "label": "Max players",
      "default": "80",
      "required": true,
      "pattern": "[0-9]{1,3}"
    }
  ],
  "notes": "Squad uses the game port plus the next port up (game port + 1) for its two traffic channels - leave a few ports of headroom between multiple instances on one host. RCON password is set in SquadGame/ServerConfig/Rcon.cfg after first run. Needs 32-bit compat libraries (lib32gcc-s1, lib32stdc++6), already installed by scripts/install.sh for SteamCMD."
}
