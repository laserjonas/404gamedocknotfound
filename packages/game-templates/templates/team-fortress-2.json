{
  "id": "team-fortress-2",
  "name": "Team Fortress 2 Dedicated Server",
  "description": "TF2 dedicated server, installed via SteamCMD (anonymous).",
  "installMethod": "steamcmd",
  "steam": {
    "appId": 232250,
    "anonymous": true
  },
  "os": ["linux"],
  "ports": [{ "name": "Game/Query", "port": 27015, "protocol": "both" }],
  "start": {
    "executable": "./srcds_run",
    "args": [
      "-game",
      "tf",
      "-console",
      "-port",
      "{{GAME_PORT}}",
      "+map",
      "{{MAP}}",
      "+maxplayers",
      "{{MAX_PLAYERS}}",
      "+hostname",
      "{{SERVER_NAME}}"
    ],
    "workingDir": "."
  },
  "env": {},
  "stop": {
    "method": "command",
    "command": "quit",
    "timeoutSeconds": 60
  },
  "console": {
    "supportsInput": true
  },
  "configFiles": [
    {
      "path": "tf/cfg",
      "description": "Server configuration (server.cfg etc.), created after first run",
      "createdByServer": true
    }
  ],
  "variables": [
    {
      "key": "SERVER_NAME",
      "label": "Server name",
      "default": "GameDock TF2",
      "required": true
    },
    {
      "key": "GAME_PORT",
      "label": "Game port (UDP+TCP)",
      "default": "27015",
      "required": true,
      "pattern": "[0-9]{2,5}"
    },
    {
      "key": "MAP",
      "label": "Start map",
      "default": "ctf_2fort",
      "required": true,
      "pattern": "[A-Za-z0-9_]{1,64}"
    },
    {
      "key": "MAX_PLAYERS",
      "label": "Max players",
      "default": "24",
      "required": true,
      "pattern": "[0-9]{1,3}"
    }
  ],
  "notes": "Public (internet-visible) servers need a Steam Game Server Login Token (GSLT) from https://steamcommunity.com/dev/managegameservers - add \"+sv_setsteamaccount\" and your token as extra startup arguments in the startup editor. Needs 32-bit compat libraries (lib32gcc-s1, lib32stdc++6), already installed by scripts/install.sh for SteamCMD."
}
