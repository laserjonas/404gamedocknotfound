{
  "id": "unturned",
  "name": "Unturned Dedicated Server",
  "description": "Unturned dedicated server, installed via SteamCMD (anonymous).",
  "installMethod": "steamcmd",
  "steam": {
    "appId": 1110390,
    "anonymous": true
  },
  "os": ["linux"],
  "ports": [
    { "name": "Game", "port": 27015, "protocol": "udp" },
    { "name": "Query", "port": 27016, "protocol": "udp" }
  ],
  "start": {
    "executable": "./ServerHelper.sh",
    "args": ["+InternetServer/GameDock", "-nographics", "-batchmode"],
    "workingDir": "."
  },
  "env": {},
  "stop": {
    "method": "sigterm",
    "timeoutSeconds": 60
  },
  "console": {
    "supportsInput": false
  },
  "configFiles": [
    {
      "path": "Servers/GameDock",
      "description": "Server config incl. Commands.dat, written by GameDock on first install and by the server as it runs"
    }
  ],
  "setupFiles": [
    {
      "path": "Servers/GameDock/Commands.dat",
      "content": "name \"{{SERVER_NAME}}\"\nport {{GAME_PORT}}\npassword \"{{SERVER_PASSWORD}}\"\nmaxplayers {{MAX_PLAYERS}}\nmap \"{{MAP}}\"\n"
    }
  ],
  "variables": [
    {
      "key": "SERVER_NAME",
      "label": "Server name",
      "default": "GameDock Unturned",
      "required": true
    },
    {
      "key": "GAME_PORT",
      "label": "Game port (UDP, query uses port+1)",
      "default": "27015",
      "required": true,
      "pattern": "[0-9]{2,5}"
    },
    {
      "key": "SERVER_PASSWORD",
      "label": "Server join password (blank = no password)",
      "default": "",
      "required": false
    },
    {
      "key": "MAX_PLAYERS",
      "label": "Max players",
      "default": "24",
      "required": true,
      "pattern": "[0-9]{1,3}"
    },
    {
      "key": "MAP",
      "label": "Map",
      "default": "PEI",
      "required": true,
      "pattern": "[A-Za-z0-9_ ]{1,64}"
    }
  ],
  "notes": "Commands.dat is generated once on install from the variables above; edit it directly afterwards for anything not exposed here. The raw Unturned server process doesn't read console commands over stdin, so GameDock stops it with SIGTERM rather than a graceful in-game save+shutdown command - the world autosaves periodically regardless."
}
